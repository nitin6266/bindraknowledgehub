# Environment variables — copy to `.env.local` for local development.
# All values are safe placeholders; replace before production.

# Public site URL (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.bindraknowledgehub.com

# Supabase Auth (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase privileged admin client (server-only, bypasses RLS).
# NEVER expose this key to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Database (server-only, used by Prisma)
# Use the connection pooler URL for serverless environments.
DATABASE_URL=postgresql://postgres:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Use the direct URL for migrations and introspection.
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Analytics / integrations (reserved for future sprints)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# API / secret keys (server-only, never exposed to client)
CONTACT_FORM_API_URL=
